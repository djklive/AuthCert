generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Apprenant {
  id_apprenant     Int            @id @default(autoincrement())
  email            String         @unique
  motDePasse       String
  statut           Statut         @default(EN_ATTENTE)
  dateCreation     DateTime       @default(now())
  dateModification DateTime       @updatedAt
  nom              String
  telephone        String?
  prenom           String
  walletAddress    String?        @unique
  
  // Relations many-to-many avec les établissements
  liaisons         LiaisonApprenantEtablissement[]
  certificats      Certificat[]
  demandesCertificat DemandeCertificat[]
  
  // Relation avec le coffre-fort des clés privées
  walletVault      WalletVault? @relation("ApprenantWallet")
  
  // Relations avec les sessions
  sessions         Session[] @relation("ApprenantSessions")
  
  // Relations avec les notifications
  notifications    Notification[] @relation("ApprenantNotifications")

  @@map("apprenants")
}

model Etablissement {
  id_etablissement                  Int                     @id @default(autoincrement())
  nomEtablissement                  String
  emailEtablissement                String                  @unique
  motDePasseEtablissement           String
  rccmEtablissement                 String?                 @unique
  typeEtablissement                 TypeEtablissement
  typeOrganisation                  TypeOrganisation         @default(ETABLISSEMENT_ENSEIGNEMENT)
  dateCreation                      DateTime                @default(now())
  dateModification                  DateTime                @updatedAt
  adresseEtablissement              String
  telephoneEtablissement            String
  nomResponsableEtablissement       String
  emailResponsableEtablissement     String
  telephoneResponsableEtablissement String
  statut                            Statut                  @default(EN_ATTENTE)
  smartContractAddress              String?                 @unique
  
  // Champs spécifiques selon le type d'organisation
  niu                               String?                 // Numéro d'Identifiant Unique (pour centres de formation)
  numeroAgrement                    String?                 // Numéro d'agrément MINEFOP
  arreteCreation                    String?                 // Référence arrêté de création (pour établissements d'enseignement)
  ministereTutelle                  String?                 // Ministère de tutelle
  
  // Relations many-to-many avec les apprenants
  liaisons                          LiaisonApprenantEtablissement[]
  documents                         DocumentEtablissement[]
  certificats                       Certificat[]
  demandesCertificat                DemandeCertificat[]
  formations                        Formation[]              // Nouvelle relation
  
  // Relation avec le coffre-fort des clés privées
  walletVault                       WalletVault? @relation("EtablissementWallet")
  
  // Relations avec les sessions
  sessions                          Session[] @relation("EtablissementSessions")
  
  // Relations avec les notifications
  notifications                     Notification[] @relation("EtablissementNotifications")

  // Abonnement et paiements
  subscription                      Subscription? @relation("EtablissementSubscription")
  paiements                         Payment[]     @relation("EtablissementPayments")

  @@map("etablissements")
}

model Admin {
  id_admin         Int      @id @default(autoincrement())
  email            String   @unique
  motDePasse       String
  statut           Statut   @default(ACTIF)
  dateCreation     DateTime @default(now())
  dateModification DateTime @updatedAt
  nom              String
  prenom           String
  
  // Relations avec les sessions
  sessions         Session[] @relation("AdminSessions")
  
  // Relations avec les notifications
  notifications    Notification[] @relation("AdminNotifications")

  @@map("admins")
}

model Session {
  id        Int   @id @default(autoincrement())
  userId    Int
  userType  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations optionnelles pour l'intégrité référentielle
  // Note: Une seule relation sera non-null selon userType
  apprenantId     Int?
  etablissementId Int?
  adminId         Int?

  apprenant     Apprenant?     @relation("ApprenantSessions", fields: [apprenantId], references: [id_apprenant], onDelete: Cascade)
  etablissement Etablissement? @relation("EtablissementSessions", fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  admin         Admin?         @relation("AdminSessions", fields: [adminId], references: [id_admin], onDelete: Cascade)

  @@map("sessions")
}

model DocumentEtablissement {
  id              Int            @id @default(autoincrement())
  etablissementId Int
  typeDocument    TypeDocumentEtablissement
  nomFichier      String
  typeMime        String
  tailleFichier   Int
  cheminFichier   String?
  statut          StatutDocument @default(EN_ATTENTE)
  dateUpload      DateTime       @default(now())
  dateValidation  DateTime?
  commentaires    String?
  etablissement   Etablissement  @relation(fields: [etablissementId], references: [id_etablissement])

  @@map("documents_etablissement")
}

// ===============================================
//                CERTIFICATS
// ===============================================

model Certificat {
  id               Int               @id @default(autoincrement())
  uuid             String            @unique
  etablissementId  Int
  apprenantId      Int
  formationId      Int?              // Nouveau champ optionnel
  titre            String
  mention          String?
  dateObtention    DateTime
  pdfUrl           String?
  pdfHash          String?
  statut           StatutCertificat  @default(BROUILLON)
  txHash           String?
  contractAddress  String?
  issuedAt         DateTime?
  createdAt        DateTime          @default(now())
  
  // Nouveaux champs pour le tracking des publications
  emissionTxHash String?            // Hash de la transaction d'émission
  emissionAttempts Int             @default(0)  // Nombre de tentatives d'émission
  lastEmissionAttempt DateTime?    // Dernière tentative d'émission
  
  // Nouveaux champs pour le tracking des révocations
  revocationTxHash String?           // Hash de la transaction de révocation
  revocationAttempts Int            @default(0)  // Nombre de tentatives de révocation
  lastRevocationAttempt DateTime?   // Dernière tentative de révocation
  revocationReason String?          // Raison de la révocation

  etablissement    Etablissement     @relation(fields: [etablissementId], references: [id_etablissement])
  apprenant        Apprenant         @relation(fields: [apprenantId], references: [id_apprenant])
  formation        Formation?        @relation(fields: [formationId], references: [id]) // Nouvelle relation
  verificationStats VerificationStat[] // Statistiques de vérification

  @@map("certificats")
}

// ===============================================
//                FORMATIONS
// ===============================================

model Formation {
  id                Int               @id @default(autoincrement())
  etablissementId   Int
  nomFormation      String
  description       String?
  typeFormation     TypeFormation
  dureeFormation    String?           // "6 mois", "2 ans", etc.
  niveauFormation   NiveauFormation?
  statut            StatutFormation   @default(ACTIF)
  dateCreation      DateTime          @default(now())
  dateModification  DateTime          @updatedAt
  
  // Relations
  etablissement     Etablissement     @relation(fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  certificats       Certificat[]
  
  @@map("formations")
}

enum Statut {
  EN_ATTENTE
  ACTIF
  SUSPENDU
  REJETE
}

enum TypeEtablissement {
  UNIVERSITE_PUBLIQUE
  UNIVERSITE_PRIVEE
  INSTITUT_SUPERIEUR
  ECOLE_TECHNIQUE
  CENTRE_FORMATION
  AUTRE
}

enum TypeOrganisation {
  ETABLISSEMENT_ENSEIGNEMENT    // Établissements d'enseignement (MINESUP, MINESEC, MINEDUB)
  CENTRE_FORMATION_PROFESSIONNELLE  // Centres de formation professionnelle (MINEFOP)
  ENTREPRISE                     // Entreprises (pour certifications internes)
}

enum StatutDocument {
  EN_ATTENTE
  VALIDE
  REJETE
  EXPIRED
}

enum TypeDocumentEtablissement {
  // Documents communs
  CNI_REPRESENTANT
  LOGO_ETABLISSEMENT
  PLAQUETTE
  
  // Documents pour établissements d'enseignement
  ARRETE_CREATION
  AUTORISATION_EXERCER
  LETTRE_NOMINATION
  
  // Documents pour centres de formation professionnelle
  RCCM
  NIU
  AGREMENT_MINEFOP
  POUVOIR_REPRESENTANT
  
  // Documents pour entreprises
  CARTE_CONTRIBUABLE
  POUVOIR_DG
}

enum StatutCertificat {
  BROUILLON
  A_EMETTRE
  EN_COURS_EMISSION    // Nouveau statut pour les publications en cours
  EMIS
  EMISSION_ECHEC       // Nouveau statut pour les publications qui ont échoué
  EN_COURS_REVOCATION  // Nouveau statut pour les révocations en cours
  REVOQUE
  REVOQUE_ECHEC        // Nouveau statut pour les révocations qui ont échoué
}

// Coffre-fort pour stocker les clés privées chiffrées
model WalletVault {
  id         Int      @id @default(autoincrement())
  ownerType  String   // 'apprenant' | 'etablissement'
  ownerId    Int
  iv         String
  authTag    String
  cipherText String
  createdAt  DateTime @default(now())

  // Relations optionnelles pour l'intégrité référentielle
  // Note: Une seule relation sera non-null selon ownerType
  apprenantId     Int? @unique
  etablissementId Int? @unique

  apprenant     Apprenant?     @relation("ApprenantWallet", fields: [apprenantId], references: [id_apprenant], onDelete: Cascade)
  etablissement Etablissement? @relation("EtablissementWallet", fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)

  @@index([ownerType, ownerId])
  @@map("wallet_vault")
}
// Nouveau modèle pour gérer les liaisons many-to-many entre apprenants et établissements
model LiaisonApprenantEtablissement {
  id                Int      @id @default(autoincrement())
  apprenantId       Int
  etablissementId   Int
  statutLiaison     StatutLiaison @default(EN_ATTENTE)
  dateDemande       DateTime @default(now())
  dateApprobation   DateTime?
  dateRejet         DateTime?
  messageDemande    String?
  messageReponse    String?
  approuvePar       Int?     // ID de l'admin qui a approuvé
  
  // Relations
  apprenant         Apprenant @relation(fields: [apprenantId], references: [id_apprenant], onDelete: Cascade)
  etablissement     Etablissement @relation(fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  
  @@unique([apprenantId, etablissementId])
  @@map("liaisons_apprenant_etablissement")
}

enum StatutLiaison {
  EN_ATTENTE
  APPROUVE
  REJETE
  SUSPENDU
}

// Nouveau modèle pour les demandes de certificat
model DemandeCertificat {
  id                Int      @id @default(autoincrement())
  apprenantId       Int
  etablissementId   Int
  titre             String
  description       String?
  messageDemande    String?
  statutDemande     StatutDemandeCertificat @default(EN_ATTENTE)
  dateDemande       DateTime @default(now())
  dateTraitement    DateTime?
  messageReponse    String?
  traitePar         Int?     // ID de l'admin qui a traité
  
  // Relations
  apprenant         Apprenant @relation(fields: [apprenantId], references: [id_apprenant], onDelete: Cascade)
  etablissement     Etablissement @relation(fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  
  // Documents joints
  documents         DocumentDemandeCertificat[]
  
  @@map("demandes_certificat")
}

model DocumentDemandeCertificat {
  id                Int      @id @default(autoincrement())
  demandeId         Int
  nomFichier        String
  typeMime          String
  tailleFichier     Int
  cheminFichier     String
  dateUpload        DateTime @default(now())
  
  // Relations
  demande           DemandeCertificat @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  
  @@map("documents_demande_certificat")
}

enum StatutDemandeCertificat {
  EN_ATTENTE
  APPROUVE
  REJETE
  EN_COURS_TRAITEMENT
}

// ===============================================
//                ENUMS FORMATIONS
// ===============================================

enum TypeFormation {
  DIPLOME
  CERTIFICAT_FORMATION
  ATTESTATION_PRESENCE
  CERTIFICATION_COMPETENCES
  FORMATION_CONTINUE
  STAGE
  SEMINAIRE
}

enum NiveauFormation {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
  EXPERT
}

enum StatutFormation {
  ACTIF
  INACTIF
  ARCHIVE
}

// ===============================================
//                STATISTIQUES DE VÉRIFICATION
// ===============================================

model VerificationStat {
  id                Int      @id @default(autoincrement())
  certificatId      Int
  verifiedAt        DateTime @default(now())
  ipAddress         String?   // Adresse IP du vérificateur
  userAgent         String?   // Navigateur utilisé
  verificationType  String   @default("public") // "public" ou "qr"
  
  // Relations
  certificat        Certificat @relation(fields: [certificatId], references: [id], onDelete: Cascade)
  
  @@map("verification_stats")
}

// ===============================================
//                NOTIFICATIONS
// ===============================================

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      // ID de l'utilisateur destinataire
  userType    String   // 'apprenant' | 'etablissement' | 'admin'
  type        TypeNotification
  titre       String
  message     String
  lu          Boolean  @default(false)
  important   Boolean  @default(false)
  lienAction  String?  // URL ou route vers laquelle rediriger
  metadonnees Json?    // Données additionnelles (certificatId, demandeId, etc.)
  createdAt   DateTime @default(now())
  readAt      DateTime? // Date de lecture
  
  // Relations optionnelles pour l'intégrité référentielle
  apprenantId     Int?
  etablissementId Int?
  adminId         Int?
  
  apprenant     Apprenant?     @relation("ApprenantNotifications", fields: [apprenantId], references: [id_apprenant], onDelete: Cascade)
  etablissement Etablissement? @relation("EtablissementNotifications", fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  admin         Admin?         @relation("AdminNotifications", fields: [adminId], references: [id_admin], onDelete: Cascade)
  
  @@index([userId, userType, lu])
  @@index([createdAt])
  @@map("notifications")
}

enum TypeNotification {
  NOUVEAU_CERTIFICAT      // Un nouveau certificat a été émis
  VERIFICATION_CERTIFICAT // Quelqu'un a vérifié un certificat
  DEMANDE_LIAISON_APPRENANT // Nouvelle demande de liaison d'un étudiant
  DEMANDE_LIAISON_APPROUVEE // Demande de liaison approuvée
  DEMANDE_LIAISON_REJETEE   // Demande de liaison rejetée
  DEMANDE_CERTIFICAT_NOUVELLE // Nouvelle demande de certificat
  DEMANDE_CERTIFICAT_APPROUVEE // Demande de certificat approuvée
  DEMANDE_CERTIFICAT_REJETEE   // Demande de certificat rejetée
  CERTIFICAT_REVOQUE      // Un certificat a été révoqué
  NOUVELLE_SESSION        // Nouvelle connexion détectée
  SECURITE_ALERTE         // Alerte de sécurité
  SYSTEME_MISE_A_JOUR     // Mise à jour système
  ABONNEMENT_EXPIRE       // Abonnement expiré
  ABONNEMENT_RENOUVELE    // Abonnement renouvelé
}

// ===============================================
//          RÉCUPÉRATION DE MOT DE PASSE
// ===============================================

model PasswordReset {
  id          Int      @id @default(autoincrement())
  email       String
  userType    String   // 'apprenant' | 'etablissement' | 'admin'
  token       String   @unique
  expiresAt   DateTime
  used        Boolean  @default(false)
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  ipAddress   String?  // Pour traçabilité
  
  @@index([email, userType, used])
  @@index([token, expiresAt])
  @@map("password_resets")
}

// ===============================================
//                ABONNEMENTS
// ===============================================

// Un abonnement par établissement (essai gratuit puis plan payant prépayé).
model Subscription {
  id                 Int      @id @default(autoincrement())
  etablissementId    Int      @unique
  plan               String   // 'TRIAL' | 'PRO' | 'EXCLUSIVE' (cf. config/plans.js)
  statut             StatutAbonnement  @default(TRIAL)
  periode            PeriodeAbonnement @default(MENSUEL)
  dateDebut          DateTime @default(now())
  dateFin            DateTime
  annulationDemandee Boolean  @default(false)
  derniereReference  String?  // dernière référence de paiement appliquée
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  etablissement      Etablissement @relation("EtablissementSubscription", fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  paiements          Payment[]

  @@map("subscriptions")
}

// Trace de chaque tentative/transaction de paiement (NotchPay).
model Payment {
  id                Int      @id @default(autoincrement())
  etablissementId   Int
  subscriptionId    Int?
  reference         String   @unique  // référence interne (idempotence)
  notchpayReference String?            // référence renvoyée par NotchPay
  montant           Int                // en FCFA
  devise            String   @default("XAF")
  plan              String
  periode           PeriodeAbonnement
  statut            StatutPaiement @default(EN_ATTENTE)
  paymentUrl        String?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  etablissement     Etablissement @relation("EtablissementPayments", fields: [etablissementId], references: [id_etablissement], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([etablissementId])
  @@index([statut])
  @@map("payments")
}

enum StatutAbonnement {
  TRIAL
  ACTIF
  PAST_DUE
  EXPIRE
  ANNULE
}

enum PeriodeAbonnement {
  MENSUEL
  ANNUEL
}

enum StatutPaiement {
  EN_ATTENTE
  REUSSI
  ECHOUE
  ANNULE
}
